{
  "name": "markethub-monorepo",
  "private": true,
  "workspaces": [
    "frontend/*",
    "backend/*",
    "packages/*"
  ],
  "scripts": {
    "_comment_auth": "Backend Auth Service",
    "dev:auth": "npm run dev -w backend/auth-service",

    "_comment_seller": "Seller frontend app",
    "dev:seller": "npm run dev -w frontend/seller-app",

    "_comment_admin": "Admin frontend app",
    "dev:admin": "npm run dev -w frontend/admin-app",

    "_comment_dropshipper": "Dropshipper frontend app",
    "dev:dropshipper": "npm run dev -w frontend/dropshipper-app",

    "_comment_customer": "Customer frontend app",
    "dev:customer": "npm run dev -w frontend/customer-app",

    "_comment_owner": "Owner frontend app",
    "dev:owner": "npm run dev -w frontend/owner-app",

    "_comment_frontend": "Run all frontend apps in parallel",
    "dev:frontend": "npm-run-all --parallel dev:seller dev:admin dev:dropshipper dev:customer dev:owner",

    "_comment_backend": "Run backend services (currently only auth)",
    "dev:backend": "npm-run-all --parallel dev:auth",
    
    "_comment_hub": "Run frontend + backend together",
    "dev:hub": "npm-run-all --parallel dev:frontend dev:backend"
  },
  "dependencies": {
    "sonner": "^2.0.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}